{
  "name": "thay-homebase",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run postbuild",
    "postbuild": "sed -i.bak 's/ crossorigin//g' dist/index.html && rm -f dist/index.html.bak",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name=thay-homebase"
  },
  "dependencies": {
    "gsap": "^3.12.5"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "wrangler": "^3.90.0"
  }
}