# --- thay-auth runtime config (kept out of git) ---
# Copy from .env.example and fill the secrets.

# Public bind port
PORT=3749

# --- PocketBase (the live hcgi/platform instance) ---
PB_URL=https://thaypley.com/hcgi/platform
PB_ADMIN_EMAIL=admin@thaypley.com
PB_ADMIN_PASSWORD=__fill__
PB_DATA_PATH=/pb_data/data.db

# --- Bypass the broken PB admin POST /api/collections/users/records ---
# When 1, /auth/signup writes the user row directly to PB's sqlite
# (requires the PB data dir be bind-mounted at /pb_data, see docker-compose.yml).
# The direct-sql path requires python3 + bcrypt inside the container
# (apk add python3 py3-bcrypt, already in the Dockerfile).
DIRECT_SQL_USERS=1

# --- JWT secret for device tokens (signs /devices/pair tokens) ---
THAY_AUTH_JWT_SECRET=__fill__

# --- CORS ---
CORS_ORIGINS=https://thaypley.com,https://auth.thaypley.com,http://localhost:5173

# --- Email (SMTP for verification + password reset) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=__fill__
SMTP_FROM=noreply@thaypley.com

# --- Invite defaults ---
INVITE_CODE_PREFIX=TP
INVITE_DEFAULT_MAX_USES=1

# --- Logging ---
LOG_LEVEL=info
