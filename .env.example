# thay-auth configuration
PORT=3749

# PocketBase instance B (universal auth)
PB_URL=http://127.0.0.1:8091
PB_ADMIN_EMAIL=admin@thaypley.com
PB_ADMIN_PASSWORD=

# JWT secret for device tokens (thay-auth signs these)
THAY_AUTH_JWT_SECRET=change-me-to-a-long-random-string

# CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3749

# Email (SMTP for verification & password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@thaypley.com

# Invite defaults
INVITE_CODE_PREFIX=TP
INVITE_DEFAULT_MAX_USES=1
