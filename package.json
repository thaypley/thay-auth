{
  "name": "thay-auth",
  "version": "1.0.0",
  "description": "Universal auth microservice for every thaypley application",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
